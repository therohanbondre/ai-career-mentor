{
  /* 
   * Architectural Decision: Prettier Configuration
   * - Consistent code formatting across the project
   * - Enforces style guide automatically
   * - Reduces code review friction
   */
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "bracketSpacing": true,
  "jsxSingleQuote": false,
  "jsxBracketSameLine": false
}
